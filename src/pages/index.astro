---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import Review from "../components/Review.astro";
import pancakes1 from "../images/pancakes1.jpg";
import pancakes2 from "../images/pancakes2.jpg";
import pancakes3 from "../images/pancakes3.jpg";
import pancakes4 from "../images/pancakes4.jpg";
import pancakes5 from "../images/pancakes5.jpg";
---

<Layout title="Camping Pancakes">
  <div style="position: relative; width: 100vw; margin: -1.45rem calc(50% - 50vw) 1.45rem;">
    <Image
      src={pancakes1}
      alt="pancakes on the griddle"
      widths={[640, 960, 1440, 1920]}
      sizes="100vw"
      quality={80}
      format="webp"
      style="display: block; width: 100%; height: 55vh; object-fit: cover; margin: 0;"
    />
    <div
      style="position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; background: rgba(0, 0, 0, 0.4);"
    >
      <div style="color: white; text-align: center; padding: 0 1.0875rem; max-width: 700px;">
        <p style="font-size: clamp(22px, 4vw, 36px); line-height: 1.25; margin-bottom: 0.7rem;">
          “I know how to make them. I just don't know how to eat them.”
        </p>
        <p style="margin: 0; font-size: 18px;">–Lionel Norman, Chef</p>
      </div>
    </div>
  </div>
  <div style="margin: 0 auto 1.45rem; max-width: 600px; font-family: 'Noto Sans Mono', monospace;">
    <h2>Menu</h2>
    <div style="display: flex; align-items: baseline; margin-bottom: 0.725rem;">
      <span>Full Stack (4 small pancakes)<sup>GF</sup><sup>*</sup></span>
      <span
        style="flex: 1; margin: 0 0.5rem; border-bottom: 2px dotted hsla(0, 0%, 0%, 0.4); transform: translateY(-4px);"
      ></span>
      <span>Free</span>
    </div>
    <div style="display: flex; align-items: baseline; margin-bottom: 1.45rem;">
      <span>Half Stack (2 small pancakes)<sup>GF</sup><sup>*</sup></span>
      <span
        style="flex: 1; margin: 0 0.5rem; border-bottom: 2px dotted hsla(0, 0%, 0%, 0.4); transform: translateY(-4px);"
      ></span>
      <span>Free</span>
    </div>
    <p style="font-size: 0.85rem;">
      All stacks served with your choice of maple syrup or blackberry raspberry syrup. Menu subject
      to ingredient availability. Kitchen closes at 11:50am sharp.
    </p>
    <p style="font-size: 0.85rem; margin-bottom: 0;"><sup>GF</sup> Gluten free</p>
    <p style="font-size: 0.85rem; margin-bottom: 0.725rem;"><sup>*</sup> Comes pre-buttered</p>
  </div>
  <div style="margin: 0 auto; max-width: 600px;">
    <h2>Reviews</h2>
    <Review name="Jared Norman" label="Happy customer" rating={5} images={[pancakes2, pancakes3]}>
      These are the best camping pancakes out there! I always go back for seconds! He cooks
      pancakes just like my dad used to.
    </Review>
    <Review name="Alistair Norman" label="Satisfied customer" rating={4}>
      Not the best customer service, but great vibe and good pancakes.
    </Review>
    <Review name="Allison Larson" label="Happy customer" rating={5} images={[pancakes4]}>
      They're really good!
    </Review>
    <Review name="Julia Tschanz" label="Whiny customer" rating={4} images={[pancakes5]}>
      The chairs kinda suck at this restaurant, but I'm pretty sure I could eat an infinity amount.
    </Review>
  </div>
  <dialog
    id="lightbox"
    style="border: none; padding: 0; background: transparent; max-width: 90vw; max-height: 90vh;"
  >
    <img
      id="lightbox-img"
      src=""
      alt="Review photo"
      style="display: block; max-width: 90vw; max-height: 90vh; margin: 0;"
    />
  </dialog>
</Layout>

<style>
  #lightbox::backdrop {
    background: rgba(0, 0, 0, 0.75);
  }
</style>

<script>
  const dialog = document.getElementById("lightbox") as HTMLDialogElement;
  const img = document.getElementById("lightbox-img") as HTMLImageElement;
  document.querySelectorAll<HTMLAnchorElement>("a.review-photo").forEach((link) => {
    link.addEventListener("click", (event) => {
      event.preventDefault();
      img.src = link.dataset.full ?? link.href;
      dialog.showModal();
    });
  });
  dialog.addEventListener("click", () => dialog.close());
</script>
